datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ADMIN") // SUPER_ADMIN, ADMIN, EDITOR
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id           String   @id @default(uuid())
  name         String
  email        String
  phone        String
  destination  String
  packageSlug  String?
  travelDate   String?
  adults       Int      @default(1)
  children     Int      @default(0)
  budget       String?
  message      String?
  status       String   @default("NEW") // NEW, CONTACTED, IN_PROGRESS, BOOKED, LOST
  assignedTo   String?
  notes        String?  // Timeline logs or staff updates
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Package {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  destinationSlug String
  duration        String   // e.g. "2 Days / 1 Night"
  price           Float
  offerPrice      Float?
  overview        String
  highlights      String   // Semicolon-separated values
  itinerary       String   // JSON string storing dynamic day-wise details
  inclusions      String   // Semicolon-separated values
  exclusions      String   // Semicolon-separated values
  hotelInfo       String?
  transportInfo   String?
  mealsInfo       String?
  difficulty      String   @default("Easy") // Easy, Moderate, Challenging
  season          String   @default("Year-round")
  images          String   // Semicolon-separated URL string
  isFeatured      Boolean  @default(false)
  status          String   @default("PUBLISHED") // DRAFT, PUBLISHED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Destination {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String
  whyVisit    String?
  bestTime    String
  attractions String   // JSON or Semicolon-separated
  image       String
  gallery     String   // Semicolon-separated URLs
  isPopular   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String
  category    String
  tags        String?
  authorName  String   @default("Travel Expert")
  image       String
  readTime    String   @default("5 mins")
  isPublished Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  id        String   @id @default("global")
  phone1    String   @default("+91 9450204681")
  phone2    String   @default("+91 6290350925")
  email1    String   @default("info@theenchantingholidays.com")
  email2    String   @default("enchantingholidaysvns@gmail.com")
  whatsapp  String   @default("+919450204681")
  address   String   @default("S-19/132-5A, Near PWD Office (Varuna Bridge), Varanasi - 221002, Uttar Pradesh, India")
  facebook  String?
  instagram String?
  youtube   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
